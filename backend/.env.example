# Copy this to .env for local dev, or set these as environment variables
# in your Render service settings for production. Every value the app
# actually reads (app/config.py) is listed here.

# --- Database ---
# Local dev default (adjust to your local Postgres):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_coach
# Production (Neon): paste the connection string from your Neon dashboard
# as-is - it already includes ?sslmode=require, which psycopg2 honors
# directly from the URL. No other changes needed.
# DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require

# --- Auth ---
# MUST be overridden in production - never deploy with a guessable secret.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM providers (Gemini primary, Groq/OpenRouter as automatic fallback) ---
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq: https://console.groq.com/keys
# REQUIRED - not just an optional LLM fallback anymore. Speech-to-text
# (audio answers) now runs via Groq's hosted Whisper API directly, so
# leaving this blank breaks the audio answer endpoint entirely, not just
# the LLM fallback chain.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter: https://openrouter.ai/keys (leave blank to skip this fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# --- CORS ---
# Local dev default. In production, set this to your deployed Vercel URL -
# localhost:5173 stays allowed automatically either way (see app/main.py).
FRONTEND_URL=http://localhost:5173

# --- File upload ---
MAX_UPLOAD_MB=10
UPLOAD_DIR=./uploads
